  "info": {
    "title": "TransitOps API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/drivers": {
      "get": {
        "description": "List drivers. ``dispatchable=true`` returns only eligible drivers\n(Available with a licence that has not expired).",
        "operationId": "list_drivers_api_v1_drivers_get",
        "parameters": [
          {
            "in": "query",
            "name": "dispatchable",
            "required": false,
            "schema": {
              "default": false,
              "title": "Dispatchable",
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/DriverRead"
                  },
                  "title": "Response List Drivers Api V1 Drivers Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Drivers",
        "tags": [
          "drivers"
        ]
      },
      "post": {
        "description": "Create a driver profile. ``license_no`` must be unique.",
        "operationId": "create_driver_api_v1_drivers_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DriverCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DriverRead"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Create Driver",
        "tags": [
          "drivers"
        ]
      }
    },
    "/api/v1/drivers/{driver_id}/status": {
      "patch": {
        "description": "Manually change a driver's duty status (Screen 3 inline control).\n\n'On Trip' is managed by the dispatcher and cannot be set by hand here.",
        "operationId": "update_driver_status_api_v1_drivers__driver_id__status_patch",
        "parameters": [
          {
            "in": "path",
            "name": "driver_id",
            "required": true,
            "schema": {
              "title": "Driver Id",
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DriverStatusUpdate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DriverRead"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Update Driver Status",
        "tags": [
          "drivers"
        ]
      }
    },
    "/api/v1/expenses": {
      "get": {
        "description": "List expenses newest first, optionally scoped to a vehicle. Includes both\nmanual (Toll/Other) and auto-posted Maintenance rows.",
        "operationId": "list_expenses_api_v1_expenses_get",
        "parameters": [
          {
            "in": "query",
            "name": "vehicle_id",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Vehicle Id"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ExpenseRead"
                  },
                  "title": "Response List Expenses Api V1 Expenses Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Expenses",
        "tags": [
          "finance"
        ]
      },
      "post": {
        "description": "Record a manual Toll or Other expense. Maintenance expenses are posted\nautomatically from the maintenance screen, so they cannot be created here.",
        "operationId": "create_expense_api_v1_expenses_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
