# Shared
APP_ENV=development

# Web - copy public values to apps/web/.env.local
NEXT_PUBLIC_APP_NAME=TransitOps
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_ENV=development

# API - copy server values to apps/api/.env
APP_NAME=TransitOps
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://transitops:transitops@localhost:5432/transitops
DATABASE_CHECK_ON_STARTUP=false
JWT_SECRET_KEY=replace-with-a-random-secret-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO
