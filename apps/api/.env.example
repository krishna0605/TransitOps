APP_NAME=TransitOps
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://transitops:transitops@localhost:5432/transitops
DATABASE_CHECK_ON_STARTUP=false
JWT_SECRET_KEY=replace-with-a-random-secret-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
REFRESH_COOKIE_NAME=transitops_refresh
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=transitops
S3_SECRET_KEY=transitops-local-only
S3_BUCKET=transitops
S3_REGION=us-east-1
MAX_UPLOAD_BYTES=10485760
CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO
