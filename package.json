{
  "name": "transitops",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "python -m uvicorn app.main:app --app-dir apps/api --reload --port 8000",
    "lint": "pnpm lint:web && pnpm lint:api",
    "lint:web": "pnpm --dir apps/web lint",
    "lint:api": "python -m ruff check apps/api",
    "format": "pnpm --dir apps/web format && python -m ruff format apps/api",
    "format:check": "pnpm --dir apps/web format:check && python -m ruff format --check apps/api",
    "typecheck": "pnpm typecheck:web && pnpm typecheck:api",
    "typecheck:web": "pnpm --dir apps/web typecheck",
    "typecheck:api": "python -m mypy apps/api/app apps/api/tests/typecheck",
    "test": "pnpm test:web && pnpm test:api",
    "test:web": "pnpm --dir apps/web test",
    "test:api": "python -m pytest apps/api",
    "build": "pnpm --dir apps/web build",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm build",
    "api:openapi": "python scripts/export_openapi.py",
    "db:upgrade": "python -m alembic -c apps/api/alembic.ini upgrade head",
    "db:downgrade": "python -m alembic -c apps/api/alembic.ini downgrade -1",
    "infra:up": "docker compose up -d postgres",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
